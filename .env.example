# URL to the main application (used for "Get Started" buttons)
APP_URL=https://app.example.com

# Postgres database used for webhook event storage + published article reads
DATABASE_URL=postgresql://user:password@localhost:5432/donkey_seo_marketing

# Donkey SEO webhook verification
DONKEY_SEO_WEBHOOK_SECRET=replace-with-webhook-signing-secret

# Donkey SEO integration API (for publication status callbacks)
DONKEY_SEO_PROJECT_ID=your-donkey-project-id
DONKEY_SEO_API_KEY=your-donkey-api-key
DONKEY_SEO_API_BASE_URL=https://api.donkeyseo.io

# Cloudflare R2 image storage
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=https://cdn.example.com
